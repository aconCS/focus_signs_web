---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Focus Signs">
  <main>
    <h1 class="text-4xl font-bold">Focus Signs</h1>
  </main>
</BaseLayout>

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Focus Signs</title>
  </head>

  <body class="bg-white text-gray-900">

    <!-- Hero -->
    <section class="min-h-screen flex flex-col justify-center items-center text-center px-6">
      <h1 class="text-5xl font-bold mb-4">
        Focus Signs
      </h1>
      <p class="text-xl text-gray-600 max-w-xl">
        High-quality custom signage for businesses that want to stand out.
      </p>

      <a href="#contact" class="mt-6 bg-black text-white px-6 py-3 rounded-lg">
        Get a Quote
      </a>
    </section>

    <!-- Services -->
    <section class="py-20 px-6 bg-gray-100">
      <h2 class="text-3xl font-bold text-center mb-10">Our Services</h2>

      <div class="grid md:grid-cols-4 gap-6 max-w-5xl mx-auto">
        <div class="bg-white p-6 rounded-xl shadow">
          Outdoor Signs
        </div>
        <div class="bg-white p-6 rounded-xl shadow">
          Indoor Signs
        </div>
        <div class="bg-white p-6 rounded-xl shadow">
          Vehicle Wraps
        </div>
        <div class="bg-white p-6 rounded-xl shadow">
          LED Signs
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="py-20 px-6 text-center">
      <h2 class="text-3xl font-bold mb-4">Contact Us</h2>
      <p class="text-gray-600">Email: info@focussigns.com</p>
      <p class="text-gray-600">Phone: +44 123 456 789</p>
    </section>

  </body>
</html>